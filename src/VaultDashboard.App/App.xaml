<Application x:Class="VaultDashboard.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:VaultDashboard.App.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <!--
                WPF-UI's own control/theme resources are merged at runtime by
                Wpf.Ui.Appearance.ApplicationThemeManager.Apply(...) (called from App.xaml.cs OnStartup),
                so only our own resources need to be merged here.
            -->
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <conv:NullToCollapsedConverter x:Key="NullToCollapsedConverter" />
            <conv:InverseBoolConverter x:Key="InverseBoolConverter" />
            <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
            <conv:CountToVisibilityConverter x:Key="CountToVisibilityConverter" />
            <conv:BoolToStatusBrushConverter x:Key="BoolToStatusBrushConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
