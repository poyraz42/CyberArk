<ui:FluentWindow x:Class="VaultDashboard.App.Views.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:vm="clr-namespace:VaultDashboard.App.ViewModels"
                 d:DataContext="{d:DesignInstance Type=vm:MainWindowViewModel}"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 mc:Ignorable="d"
                 Title="CyberArk Vault Dashboard"
                 Width="1440" Height="900"
                 MinWidth="1100" MinHeight="700"
                 ExtendsContentIntoTitleBar="True"
                 WindowStartupLocation="CenterScreen"
                 Background="{StaticResource PagePlaneBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="CyberArk Vault Dashboard" />

        <!-- Status / refresh bar -->
        <Border Grid.Row="1" Background="{StaticResource ChartSurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush.Hairline}" BorderThickness="0,0,0,1"
                Padding="20,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding State.StatusMessage, FallbackValue='Not connected. Configure a PVWA connection in Connections, then Refresh.'}"
                               Style="{StaticResource SubtleTextStyle}" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding State.LastRefreshedUtc, StringFormat='  |  Last refreshed: {0:g} UTC'}"
                               Style="{StaticResource SubtleTextStyle}" VerticalAlignment="Center"
                               Visibility="{Binding State.LastRefreshedUtc, Converter={StaticResource NullToCollapsedConverter}}" />
                </StackPanel>

                <ui:Button Grid.Column="1" Content="Refresh" Appearance="Primary"
                           Command="{Binding RefreshCommand}"
                           IsEnabled="{Binding State.IsRefreshing, Converter={StaticResource InverseBoolConverter}}" />
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource PagePlaneBrush}">
                <ListBox x:Name="NavList"
                         ItemsSource="{Binding NavItems}"
                         SelectedItem="{Binding SelectedNavItem, Mode=TwoWay}"
                         Style="{StaticResource NavRailListBoxStyle}"
                         ItemContainerStyle="{StaticResource NavRailListBoxItemStyle}"
                         Margin="8,12">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Title}" Padding="12,10" FontSize="14" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <ContentControl Grid.Column="1" Content="{Binding CurrentPage}" Margin="24" />
        </Grid>
    </Grid>
</ui:FluentWindow>
