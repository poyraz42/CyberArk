<UserControl x:Class="VaultDashboard.App.Views.Pages.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:vm="clr-namespace:VaultDashboard.App.ViewModels.Pages"
             d:DataContext="{d:DesignInstance Type=vm:SettingsViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <UserControl.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock" BasedOn="{StaticResource KpiLabelTextStyle}">
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>
        <Style x:Key="FieldStack" TargetType="StackPanel">
            <Setter Property="Margin" Value="0,0,16,12" />
        </Style>
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="Connections" Style="{StaticResource SectionHeaderTextStyle}" />

            <Border Style="{StaticResource CardPanelStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="PVWA (REST API)" Style="{StaticResource KpiLabelTextStyle}" FontSize="14" Margin="0,0,0,12" />
                    <WrapPanel>
                        <StackPanel Style="{StaticResource FieldStack}" Width="260">
                            <TextBlock Text="PVWA address (host only)" Style="{StaticResource FieldLabel}" />
                            <TextBox Text="{Binding State.PvwaProfile.Address, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Style="{StaticResource FieldStack}" Width="180">
                            <TextBlock Text="Authentication type" Style="{StaticResource FieldLabel}" />
                            <ComboBox ItemsSource="{Binding AuthenticationTypes}"
                                      SelectedItem="{Binding State.PvwaProfile.AuthenticationType}" />
                        </StackPanel>
                        <StackPanel Style="{StaticResource FieldStack}" Width="200">
                            <TextBlock Text="Username" Style="{StaticResource FieldLabel}" />
                            <TextBox Text="{Binding State.PvwaProfile.Username, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Style="{StaticResource FieldStack}" Width="200">
                            <TextBlock Text="Password" Style="{StaticResource FieldLabel}" />
                            <ui:PasswordBox Password="{Binding State.PvwaProfile.Password, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Style="{StaticResource FieldStack}" Width="180">
                            <TextBlock Text="Allow insecure TLS" Style="{StaticResource FieldLabel}" />
                            <CheckBox IsChecked="{Binding State.PvwaProfile.AllowInsecureTls}" Content="Lab/dev only" />
                        </StackPanel>
                    </WrapPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <ui:Button Content="Test connection" Command="{Binding TestPvwaConnectionCommand}"
                                   IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" Margin="0,0,8,0" />
                        <TextBlock Text="{Binding TestResultMessage}" VerticalAlignment="Center" Style="{StaticResource SubtleTextStyle}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardPanelStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <CheckBox Content="Enrich with PACLI" IsChecked="{Binding State.IncludePacli}" Margin="0,0,0,12" />
                    <WrapPanel>
                        <StackPanel Style="{StaticResource FieldStack}" Width="320">
                            <TextBlock Text="Pacli.exe path" Style="{StaticResource FieldLabel}" />
                            <TextBox Text="{Binding State.PacliProfile.ExecutablePath, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Style="{StaticResource FieldStack}" Width="180">
                            <TextBlock Text="Vault name" Style="{StaticResource FieldLabel}" />
                            <TextBox Text="{Binding State.PacliProfile.VaultName, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Style="{StaticResource FieldStack}" Width="200">
                            <TextBlock Text="Vault address" Style="{StaticResource FieldLabel}" />
                            <TextBox Text="{Binding State.PacliProfile.VaultAddress, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Style="{StaticResource FieldStack}" Width="100">
                            <TextBlock Text="Port" Style="{StaticResource FieldLabel}" />
                            <TextBox Text="{Binding State.PacliProfile.VaultPort, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Style="{StaticResource FieldStack}" Width="180">
                            <TextBlock Text="Username" Style="{StaticResource FieldLabel}" />
                            <TextBox Text="{Binding State.PacliProfile.Username, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Style="{StaticResource FieldStack}" Width="180">
                            <TextBlock Text="Password" Style="{StaticResource FieldLabel}" />
                            <ui:PasswordBox Password="{Binding State.PacliProfile.Password, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardPanelStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <CheckBox Content="Enrich with ExportVaultData (EVD)" IsChecked="{Binding State.IncludeEvd}" Margin="0,0,0,12" />
                    <WrapPanel>
                        <StackPanel Style="{StaticResource FieldStack}" Width="320">
                            <TextBlock Text="ExportVaultData.exe path" Style="{StaticResource FieldLabel}" />
                            <TextBox Text="{Binding State.EvdProfile.ExecutablePath, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Style="{StaticResource FieldStack}" Width="280">
                            <TextBlock Text="Vault.ini path" Style="{StaticResource FieldLabel}" />
                            <TextBox Text="{Binding State.EvdProfile.VaultFilePath, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Style="{StaticResource FieldStack}" Width="280">
                            <TextBlock Text="Auditor .cred file path" Style="{StaticResource FieldLabel}" />
                            <TextBox Text="{Binding State.EvdProfile.CredFilePath, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Style="{StaticResource FieldStack}" Width="280">
                            <TextBlock Text="Output folder" Style="{StaticResource FieldLabel}" />
                            <TextBox Text="{Binding State.EvdProfile.OutputFolder, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <StackPanel Orientation="Horizontal">
                <ui:Button Content="Save profiles" Appearance="Primary" Command="{Binding SaveCommand}"
                           IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
