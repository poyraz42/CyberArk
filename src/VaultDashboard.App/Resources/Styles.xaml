<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Dark-surface slice of the validated reference palette (see dataviz skill / palette.md).
        Categorical Series1..Series8 are a FIXED order - never reassigned/cycled based on filters
        or item count. Status brushes are reserved for compliance/health state and never reused
        as a categorical series color.
    -->

    <SolidColorBrush x:Key="ChartSurfaceBrush" Color="#1A1A19" />
    <SolidColorBrush x:Key="PagePlaneBrush" Color="#0D0D0D" />
    <SolidColorBrush x:Key="PrimaryInkBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="SecondaryInkBrush" Color="#C3C2B7" />
    <SolidColorBrush x:Key="MutedInkBrush" Color="#898781" />
    <SolidColorBrush x:Key="GridlineBrush" Color="#2C2C2A" />
    <SolidColorBrush x:Key="BaselineBrush" Color="#383835" />
    <SolidColorBrush x:Key="BorderBrush.Hairline" Color="#1AFFFFFF" />

    <SolidColorBrush x:Key="Series1Brush" Color="#3987E5" />
    <!-- blue -->
    <SolidColorBrush x:Key="Series2Brush" Color="#199E70" />
    <!-- aqua -->
    <SolidColorBrush x:Key="Series3Brush" Color="#C98500" />
    <!-- yellow -->
    <SolidColorBrush x:Key="Series4Brush" Color="#008300" />
    <!-- green -->
    <SolidColorBrush x:Key="Series5Brush" Color="#9085E9" />
    <!-- violet -->
    <SolidColorBrush x:Key="Series6Brush" Color="#E66767" />
    <!-- red -->
    <SolidColorBrush x:Key="Series7Brush" Color="#D55181" />
    <!-- magenta -->
    <SolidColorBrush x:Key="Series8Brush" Color="#D95926" />
    <!-- orange -->

    <SolidColorBrush x:Key="StatusGoodBrush" Color="#0CA30C" />
    <SolidColorBrush x:Key="StatusWarningBrush" Color="#FAB219" />
    <SolidColorBrush x:Key="StatusSeriousBrush" Color="#EC835A" />
    <SolidColorBrush x:Key="StatusCriticalBrush" Color="#D03B3B" />

    <Style x:Key="SectionHeaderTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource PrimaryInkBrush}" />
        <Setter Property="Margin" Value="0,0,0,12" />
    </Style>

    <Style x:Key="SubtleTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{StaticResource SecondaryInkBrush}" />
    </Style>

    <Style x:Key="CardPanelStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource ChartSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush.Hairline}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="16" />
    </Style>

    <Style x:Key="KpiValueTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="30" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource PrimaryInkBrush}" />
    </Style>

    <Style x:Key="KpiLabelTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{StaticResource MutedInkBrush}" />
        <Setter Property="Margin" Value="0,4,0,0" />
    </Style>

    <Style x:Key="NavRailListBoxStyle" TargetType="ListBox">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
    </Style>

    <Style x:Key="NavRailListBoxItemStyle" TargetType="ListBoxItem">
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0,2" />
        <Setter Property="Foreground" Value="{StaticResource SecondaryInkBrush}" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="RootBorder" CornerRadius="6" Background="Transparent">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border x:Name="AccentBar" Grid.Column="0" Background="{StaticResource Series1Brush}"
                                    CornerRadius="2" Margin="0,4" Opacity="0" />
                            <ContentPresenter Grid.Column="1" VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="RootBorder" Property="Background" Value="#14FFFFFF" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="RootBorder" Property="Background" Value="#1FFFFFFF" />
                            <Setter TargetName="AccentBar" Property="Opacity" Value="1" />
                            <Setter Property="Foreground" Value="{StaticResource PrimaryInkBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
